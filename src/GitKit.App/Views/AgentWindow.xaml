<Window x:Class="GitKit.App.Views.AgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agente — execução da User Story"
        Height="640" Width="900" MinHeight="480" MinWidth="700"
        Background="{StaticResource ParchmentBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho: dados do processo -->
        <GroupBox Grid.Row="0" Header="{Binding Job.Title}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Typo.Caption}" Text="Repositório:" Margin="0,0,10,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Typo.Caption}" Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis" Text="{Binding Job.RepositoryUrl}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Typo.Caption}" Text="Clonado em:" Margin="0,0,10,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Typo.Caption}" Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis" Text="{Binding Job.WorkingDir}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Typo.Caption}" Text="Enviar para:" Margin="0,0,10,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Typo.Caption}" Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis" Text="{Binding Job.PushUpstream}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Typo.Caption}" Text="Situação:" Margin="0,0,10,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource Typo.Caption}"
                           Text="{Binding Job.StatusLabel}" />
            </Grid>
        </GroupBox>

        <!-- Console: transcript da conversa com o agente -->
        <TextBox x:Name="TranscriptBox" Grid.Row="1" Style="{StaticResource CodeTextBox}"
                 Text="{Binding Job.TranscriptText, Mode=OneWay}" TextWrapping="Wrap" />

        <!-- Entrada de texto para o agente -->
        <Grid Grid.Row="2" Margin="0,12,0,0" IsEnabled="{Binding CanInteract}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" MinHeight="56" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                     ToolTip="Sua resposta/instrução para o agente"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                <Button Content="Enviar" MinWidth="110"
                        Style="{StaticResource PrimaryButton}" Command="{Binding SendCommand}" />
                <Button Content="Solicitar commit" MinWidth="110" Margin="0,8,0,0"
                        Command="{Binding RequestCommitCommand}"
                        ToolTip="Pede ao agente a intenção das alterações e monta a mensagem Ab#{id} ..." />
            </StackPanel>
        </Grid>

        <!-- Proposta de commit (aprovação do dev) -->
        <GroupBox Grid.Row="3" Header="Mensagem de commit (Ab#id + intenção)" Margin="0,12,0,0"
                  Visibility="{Binding Job.HasCommitProposal, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Aprovar e commitar" Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButton}" Command="{Binding ApproveCommitCommand}" />
            </Grid>
        </GroupBox>

        <!-- Ações finais -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Enviar (push)" MinWidth="140"
                    Style="{StaticResource PrimaryButton}" Command="{Binding PushCommand}"
                    Visibility="{Binding Job.IsReadyToPush, Converter={StaticResource BoolToVis}}" />
            <Button Content="Fechar" MinWidth="100" Margin="10,0,0,0" Command="{Binding CloseCommand}" />
            <ProgressBar Width="120" Height="4" Margin="16,0,0,0" IsIndeterminate="True"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <TextBlock Grid.Row="5" Margin="0,10,0,0" TextWrapping="Wrap" Style="{StaticResource Typo.Caption}"
                   Text="{Binding Job.StatusText}" />
    </Grid>
</Window>
