<Window x:Class="GitKit.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GitKit.App.Views"
        Title="git.kit — Replicação entre branches"
        Height="720" Width="1040" MinHeight="560" MinWidth="860"
        Background="{StaticResource ParchmentBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <TabItem Header="Início">
                <views:HomeView DataContext="{Binding Home}" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="Replicar branch">
                <views:BranchReplicationView DataContext="{Binding BranchReplication}" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="Cherry-pick">
                <views:CherryPickView DataContext="{Binding CherryPick}" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="User Stories">
                <views:UserStoriesView DataContext="{Binding UserStories}" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="Processos">
                <views:ProcessesView DataContext="{Binding Processes}" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="Log">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Margin="0,0,0,8"
                              Content="Registrar log dos comandos git/gh (nesta aba e em arquivo)"
                              ToolTip="Desmarcado (padrão), nenhum log é registrado"
                              IsChecked="{Binding IsLogEnabled}" />
                    <TextBox Grid.Row="1" Style="{StaticResource CodeTextBox}"
                             Text="{Binding Log, Mode=OneWay}" TextWrapping="NoWrap" />
                </Grid>
            </TabItem>

        </TabControl>

        <StatusBar Grid.Row="1" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Style="{StaticResource Typo.Caption}" Text="{Binding Processes.Summary}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Style="{StaticResource Typo.Caption}" Foreground="{StaticResource AccentBrush}"
                           Text="{Binding AttentionMessage}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
