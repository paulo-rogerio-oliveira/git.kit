<Window x:Class="GitKit.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="git.kit — Replicação de commits entre branches"
        Height="720" Width="980"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- ===================== Aba: Replicação ===================== -->
            <TabItem Header="Replicação">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ===== 1. Repositório ===== -->
                    <GroupBox Grid.Row="0" Header="1. Repositório" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="URL ou caminho:" Margin="0,0,8,4" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,4" VerticalContentAlignment="Center"
                                     ToolTip="Informe a URL de clone (https/ssh) ou o caminho de um repositório git local"
                                     Text="{Binding RepositorySource, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0" Grid.Column="2" Content="Iniciar" Margin="0,0,0,4"
                                    Command="{Binding StartCommand}" />

                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center"
                                       Margin="0,2,0,0" Foreground="#555" TextTrimming="CharacterEllipsis"
                                       Text="{Binding RepositoryPath, StringFormat=Local: {0}}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center"
                                       Margin="0,2,0,0" Foreground="#555" TextTrimming="CharacterEllipsis"
                                       Text="{Binding RepositoryUrl, StringFormat=Remote: {0}}" />
                        </Grid>
                    </GroupBox>

                    <!-- ===== 2. Branches ===== -->
                    <GroupBox Grid.Row="1" Header="2. Branches e commit" Padding="8" Margin="0,0,0,8"
                              IsEnabled="{Binding IsRepositoryReady}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Branch de origem:" />
                                <ComboBox ItemsSource="{Binding SourceBranchesView}" SelectedItem="{Binding SelectedSourceBranch}"
                                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                          DisplayMemberPath="Name"
                                          ToolTip="Digite para filtrar os branches de origem"
                                          Text="{Binding BranchFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Branch de destino (existente ou novo):" />
                                <ComboBox ItemsSource="{Binding DestinationBranchesView}" IsEditable="True"
                                          IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                          DisplayMemberPath="Name"
                                          ToolTip="Digite para filtrar/selecionar um branch existente ou informar um novo nome.&#x0a;Nome terminado em 'dev' é criado a partir de develop; caso contrário, de master."
                                          Text="{Binding DestinationBranch, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Button Grid.Row="0" Grid.Column="2" Content="Atualizar" VerticalAlignment="Bottom"
                                    Command="{Binding RefreshBranchesCommand}" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Content="Estratégia:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox Width="320" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- ===== 3. Lista de commits ===== -->
                    <GroupBox Grid.Row="2" Header="3. Commit a replicar (do branch de origem)" Padding="8" Margin="0,0,0,0"
                              IsEnabled="{Binding IsRepositoryReady}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Margin="0,0,0,6" VerticalContentAlignment="Center"
                                     ToolTip="Filtrar commits por hash, autor ou mensagem"
                                     Text="{Binding CommitFilter, UpdateSourceTrigger=PropertyChanged}" />

                            <DataGrid Grid.Row="1" ItemsSource="{Binding CommitsView}" SelectedItem="{Binding SelectedCommit}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Hash" Binding="{Binding ShortHash}" Width="80" />
                                    <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                                    <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="160" />
                                    <DataGridTextColumn Header="Mensagem" Binding="{Binding Subject}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Replicar commit" MinWidth="140" FontWeight="Bold"
                                        Command="{Binding ReplicateCommand}" />
                                <Button Content="Resolver conflitos..." Margin="8,0,0,0"
                                        Command="{Binding ResolveConflictsCommand}"
                                        Visibility="{Binding PendingManualResolution, Converter={StaticResource BoolToVis}}" />
                                <Button Content="Enviar branch (push)" Margin="8,0,0,0"
                                        Command="{Binding PushCommand}"
                                        Visibility="{Binding CanShowPush, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ===================== Aba: Log ===================== -->
            <TabItem Header="Log">
                <TextBox Margin="8" Text="{Binding Log, Mode=OneWay}" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" Background="#1E1E1E" Foreground="#DCDCDC" />
            </TabItem>

        </TabControl>

        <!-- ===== Barra de status ===== -->
        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <ProgressBar Width="120" Height="14" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
