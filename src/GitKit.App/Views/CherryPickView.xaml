<UserControl x:Class="GitKit.App.Views.CherryPickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Repositório -->
        <GroupBox Grid.Row="0" Header="Repositório GitHub" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="URL" Margin="0,0,12,0" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Margin="0,0,12,0"
                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                          ItemsSource="{Binding RepositoriesView}"
                          ToolTip="Repositórios a que você tem acesso e os recentes (digite para filtrar). Branches e commits são consultados via gh, sem clonar."
                          Text="{Binding RepositorySource, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2" Content="Carregar branches"
                        Style="{StaticResource PrimaryButton}" Command="{Binding LoadBranchesCommand}" />
            </Grid>
        </GroupBox>

        <!-- Origem / destino -->
        <GroupBox Grid.Row="1" Header="Origem e destino" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="Branch de origem" />
                    <ComboBox ItemsSource="{Binding SourceBranchesView}"
                              IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                              Text="{Binding SourceBranch, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Digite para filtrar e selecione o branch de origem." />
                </StackPanel>

                <Button Grid.Column="1" Content="Carregar commits" VerticalAlignment="Bottom"
                        Command="{Binding LoadCommitsCommand}" />

                <StackPanel Grid.Column="3">
                    <Label Content="Branch de destino (existente ou novo)" />
                    <ComboBox ItemsSource="{Binding TargetBranchesView}" IsEditable="True"
                              IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                              ToolTip="Digite para filtrar ou informar um novo nome de branch."
                              Text="{Binding TargetBranch, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Commits -->
        <GroupBox Grid.Row="2" Header="Commits a replicar (marque os desejados)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Margin="0,0,0,10"
                         ToolTip="Filtrar os commits por hash, autor ou mensagem"
                         Text="{Binding CommitFilter, UpdateSourceTrigger=PropertyChanged}" />

                <DataGrid Grid.Row="1" ItemsSource="{Binding CommitsView}" IsReadOnly="True">
                    <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Hash" Binding="{Binding ShortHash}" Width="80" />
                    <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="150" />
                    <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="170" />
                        <DataGridTextColumn Header="Mensagem" Binding="{Binding Subject}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Ações + status -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Replicar selecionados" MinWidth="180"
                    Style="{StaticResource PrimaryButton}" Command="{Binding ReplicateCommand}" />
            <TextBlock Grid.Column="1" Style="{StaticResource Typo.Caption}" Margin="14,0,0,0"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Text="{Binding StatusMessage}" />
        </Grid>
    </Grid>
</UserControl>
