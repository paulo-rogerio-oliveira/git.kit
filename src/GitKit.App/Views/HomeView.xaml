<UserControl x:Class="GitKit.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="820">

            <TextBlock Style="{StaticResource Typo.Display}" HorizontalAlignment="Center"
                       Text="O que você quer fazer?" />
            <TextBlock Style="{StaticResource Typo.Caption}" HorizontalAlignment="Center"
                       Margin="0,6,0,28"
                       Text="Escolha uma das ações. Nada é clonado até você preencher os parâmetros." />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Replicar branch -->
                <GroupBox Grid.Column="0" Header="Replicar branch">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Typo.Body}" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Text="Replica TODOS os commits de um branch para um novo branch, com destino escolhido (develop/master) e Pull Request com revisores ao final." />
                        <Button Content="Replicar branch" HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ReplicateBranchCommand}" />
                    </StackPanel>
                </GroupBox>

                <!-- Cherry-pick -->
                <GroupBox Grid.Column="2" Header="Cherry-pick">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Typo.Body}" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Text="Replica apenas os commits que você selecionar para outro branch escolhido. Os commits são listados a partir do GitHub, sem clonar." />
                        <Button Content="Cherry-pick" HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding CherryPickCommand}" />
                    </StackPanel>
                </GroupBox>

                <!-- User Stories -->
                <GroupBox Grid.Column="4" Header="User Stories">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Typo.Body}" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Text="Carrega suas User Stories do Azure DevOps, atribui a você (com task ativa) e executa o planejamento técnico com o agente Claude — commit padrão Ab#id e push ao final." />
                        <Button Content="User Stories" HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding UserStoriesCommand}" />
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
