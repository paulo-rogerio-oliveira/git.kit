<Window x:Class="GitKit.App.Views.ConflictsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolução de conflitos"
        Height="460" Width="820"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="Os arquivos abaixo estão em conflito. Clique em 'Resolver' para abrir o TortoiseGitMerge, salve a resolução e marque como resolvido; depois use 'Atualizar status'." />

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Arquivo" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Tipo de conflito" Binding="{Binding Description}" Width="170" />
                <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="70" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                <DataGridTemplateColumn Header="Ação" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Resolver" Margin="2" Padding="8,2"
                                    Command="{Binding ResolveCommand}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Atualizar status" MinWidth="120" Padding="12,4"
                    Command="{Binding RefreshCommand}" />
            <Button Content="Concluir replicação" MinWidth="140" Padding="12,4" Margin="8,0,0,0"
                    FontWeight="Bold" Command="{Binding ConcludeCommand}" />
            <ProgressBar Width="120" Height="14" Margin="8,0,0,0" IsIndeterminate="True"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#555" TextWrapping="Wrap"
                   Text="{Binding StatusMessage}" />
    </Grid>
</Window>
