# Normaliza finais de linha no repositório (LF), deixando o checkout nativo.
* text=auto

# Arquivos tipicamente Windows/script: mantêm CRLF.
*.ps1   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.sln   text eol=crlf
*.slnx  text eol=crlf

# Código e projetos.
*.cs    text
*.xaml  text
*.csproj text
*.md    text
*.yml   text
*.html  text

# Binários.
*.png   binary
*.ico   binary
*.exe   binary
*.dll   binary
